{
  "manifest_version": 3,
  "name": "Universal Video Speed",
  "version": "1.1.0",
  "description": "Finds the main <video> on any page (YouTube, X, JWPlayer, anywhere) and controls its speed (0.25x-4x) via a slider and the < / > keys.",
  "permissions": ["activeTab"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Toggle video speed control",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "run_at": "document_idle",
      "js": ["content.js"]
    }
  ]
}
